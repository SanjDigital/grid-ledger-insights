# GridLedger Protocol GL-1 — Environment Variables

# REQUIRED: Institutional API Key for mandate logging, discrepancy reports, enforcement actions
# Generate a secure random key; do not use the example value below
GRIDLEDGER_API_KEY=your-secure-api-key-here

# REQUIRED: Owner App API Key for capital allocation decisions and decision feed
# Generate a secure random key; do not use the example value below
OWNER_API_KEY=your-owner-app-key-here

# OPTIONAL: Frontend API configuration
# Default: http://localhost:8000
VITE_API_URL=http://localhost:8000

# OPTIONAL: Frontend API Key (if different from GRIDLEDGER_API_KEY)
# Leave empty to disable external API calls (development/demo mode)
VITE_API_KEY=your-frontend-api-key-here

# Database configuration (if using external database)
# DATABASE_URL=sqlite:///./gridledger.db

# Trust Anchor Repository (GitHub)
# URL of the public cycle-seals repository for verification chain
TRUST_ANCHOR_REPO_PATH=./gridledger-cycle-seals
TRUST_ANCHOR_REPO_URL=https://github.com/gridledger/gridledger-cycle-seals.git
GITHUB_TOKEN=your-github-token-here

# System Configuration
SYSTEM_ALLOCATION_ENABLED=true
MISSING_CYCLE_TIMEOUT_HOURS=48
